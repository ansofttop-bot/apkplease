class WelcomeScreen(Screen):
    def __init__(self, title, desc, img_url, next_screen, is_last=False, **kwargs):
        super().__init__(**kwargs)
        layout = BoxLayout(orientation='vertical', padding=dp(30), spacing=dp(20))

        img = AsyncImage(source=img_url, size_hint=(1, 0.5))

        lbl_title = Label(text=title, font_size='24sp', bold=True, color=ORANGE, size_hint_y=None, height=dp(50))
        lbl_desc = Label(text=desc, font_size='16sp', color=(0.8, 0.8, 0.8, 1), halign='center', valign='middle')
        lbl_desc.bind(size=lbl_desc.setter('text_size'))

        btn_text = "GET STARTED" if is_last else "CONTINUE"
        btn = Button(text=btn_text, size_hint=(None, None), size=(dp(200), dp(50)),
                     pos_hint={'center_x': 0.5}, background_color=(0,0,0,0), color=ORANGE, bold=True)

        with btn.canvas.before:
            Color(*ORANGE, 0.1)
            self.rect = RoundedRectangle(radius=[dp(25)])
            Color(*ORANGE)
            self.line = Line(width=1.2)

        def upd_btn(inst, val):
            self.rect.pos = inst.pos
            self.rect.size = inst.size
            self.line.rounded_rectangle = (inst.x, inst.y, inst.width, inst.height, dp(25))

        btn.bind(pos=upd_btn, size=upd_btn)
        btn.bind(on_release=lambda x: self.go_next(next_screen))

        layout.add_widget(Widget(size_hint_y=0.1))
        layout.add_widget(img)
        layout.add_widget(lbl_title)
        layout.add_widget(lbl_desc)
        layout.add_widget(btn)
        layout.add_widget(Widget(size_hint_y=0.1))

        self.add_widget(layout)

    def go_next(self, next_screen):
        self.manager.current = next_screen

class ChatScreen(Screen):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.load_data()
        self.main_layout = BoxLayout(orientation='vertical')

        self.header = BoxLayout(size_hint_y=None, height=dp(60), padding=[dp(15), 0])
        self.menu_btn = Button(text="—\n—\n—", size_hint=(None, None), size=(dp(40), dp(40)),
                               pos_hint={'center_y': .5}, background_color=(0,0,0,0),
                               color=ORANGE, font_size='14sp', line_height=0.6, bold=True)
        self.menu_btn.bind(on_release=self.toggle_drawer)

        self.header_label = Label(text="Chat", bold=True, color=ORANGE, font_size='18sp')

        self.new_chat_top_btn = Button(text="+", size_hint=(None, None), size=(dp(40), dp(40)),
                                       pos_hint={'center_y': .5}, background_color=(0,0,0,0),
                                       color=ORANGE, font_size='24sp', bold=True)
        self.new_chat_top_btn.bind(on_release=self.create_new_chat)

        self.header.add_widget(self.menu_btn)
        self.header.add_widget(self.header_label)
        self.header.add_widget(self.new_chat_top_btn)
        self.main_layout.add_widget(self.header)

        self.scroll = ScrollView(do_scroll_x=False)
        self.chat_box = BoxLayout(orientation='vertical', size_hint_y=None, spacing=dp(10), padding=dp(15))
        self.chat_box.bind(minimum_height=self.chat_box.setter('height'))
        self.scroll.add_widget(self.chat_box)
        self.scroll.bind(on_touch_down=self.check_close_drawer)
        self.main_layout.add_widget(self.scroll)

        self.center_label = Label(text="IGSEEK\nuncensored project", halign='center',
                                  font_size='28sp', bold=True, color=ORANGE_LOW)
        self.add_widget(self.center_label)

        self.input_wrapper = BoxLayout(size_hint_y=None, height=dp(70), padding=[dp(10), dp(10)])
        with self.input_wrapper.canvas.before:
            Color(0.1, 0.1, 0.1, 1)
            self.wrap_rect = RoundedRectangle(radius=[dp(25)])
        self.input_wrapper.bind(pos=self._upd_wrap, size=self._upd_wrap)

        self.tin = TextInput(hint_text="Message...", multiline=False, background_color=(0,0,0,0),
                             foreground_color=(1,1,1,1), cursor_color=ORANGE, font_size='16sp',
                             padding=[dp(15), dp(12)])
        self.tin.bind(on_text_validate=self.send_msg)

        self.send_btn = Button(text="SEND", size_hint=(None, 1), width=dp(85),
                               background_color=(0,0,0,0), color=ORANGE, bold=True)
        with self.send_btn.canvas.before:
            Color(*ORANGE_LOW)
            self.send_bg = RoundedRectangle(radius=[dp(20)])
        self.send_btn.bind(pos=self._upd_send, size=self._upd_send)
        self.send_btn.bind(on_release=self.send_msg)

        self.input_wrapper.add_widget(self.tin)
        self.input_wrapper.add_widget(self.send_btn)
        self.main_layout.add_widget(self.input_wrapper)
        self.add_widget(self.main_layout)

        self.drawer = BoxLayout(orientation='vertical', width=dp(280), size_hint_x=None, x=-dp(280))
        with self.drawer.canvas.before:
            Color(0.04, 0.04, 0.04, 1); self.dr_bg = RoundedRectangle(radius=[0, 20, 20, 0])
        self.drawer.bind(pos=self._upd_dr, size=self._upd_dr)

        self.chat_list_layout = BoxLayout(orientation='vertical', spacing=dp(5), size_hint_y=None, padding=[0, dp(20)])
        self.chat_list_layout.bind(minimum_height=self.chat_list_layout.setter('height'))
        dr_scroll = ScrollView(); dr_scroll.add_widget(self.chat_list_layout)
        self.drawer.add_widget(dr_scroll)
        self.add_widget(self.drawer)

        self.switch_chat(self.current_chat_id)

    def _upd_wrap(self, i, v): self.wrap_rect.pos, self.wrap_rect.size = i.pos, i.size
    def _upd_send(self, i, v): self.send_bg.pos, self.send_bg.size = i.pos, i.size
    def _upd_dr(self, i, v): self.dr_bg.pos, self.dr_bg.size = i.pos, i.size

    def load_data(self):
        if os.path.exists(DATA_FILE):
            try:
                with open(DATA_FILE, 'r', encoding='utf-8') as f:
                    data = json.load(f)
                    self.chats = {int(k): v for k, v in data["chats"].items()}
                    for k in self.chats: self.chats[k].setdefault("pinned", False)
                    self.current_chat_id = data.get("current", list(self.chats.keys())[0])
                    return
            except: pass
        self.chats = {1: {"name": "Chat", "msgs": [], "pinned": False}}; self.current_chat_id = 1

    def save_data(self):
        with open(DATA_FILE, 'w', encoding='utf-8') as f:
            json.dump({"chats": self.chats, "current": self.current_chat_id}, f, ensure_ascii=False)

    def create_new_chat(self, *args):
        if not self.chats[self.current_chat_id]["msgs"]: return
        new_id = max(self.chats.keys()) + 1
        self.chats[new_id] = {"name": "New Chat", "msgs": [], "pinned": False}
        self.switch_chat(new_id)

    def switch_chat(self, chat_id):
        self.current_chat_id = chat_id
        self.chat_box.clear_widgets()
        for m in self.chats[chat_id]["msgs"]: self.add_bubble(m['text'], m['is_user'])
        self.center_label.opacity = 0 if self.chats[chat_id]["msgs"] else 1
        self.header_label.text = self.chats[chat_id]["name"]
        self.refresh_chat_list()
        self.save_data()

    def toggle_pin(self, cid, *args):
        self.chats[cid]["pinned"] = not self.chats[cid].get("pinned", False)
        self.refresh_chat_list()
        self.save_data()

    def delete_chat(self, cid, *args):
        if len(self.chats) > 1:
            del self.chats[cid]
            if cid == self.current_chat_id: self.current_chat_id = list(self.chats.keys())[0]
        else: self.chats[cid] = {"name": "Chat", "msgs": [], "pinned": False}
        self.switch_chat(self.current_chat_id)

    def refresh_chat_list(self):
        self.chat_list_layout.clear_widgets()
        sorted_ids = sorted(self.chats.keys(), key=lambda k: (not self.chats[k].get("pinned"), -k))

        for cid in sorted_ids:
            is_curr = (cid == self.current_chat_id)
            is_pinned = self.chats[cid].get("pinned")

            row = Widget(size_hint_y=None, height=dp(50))

            lbl = Label(
                text=self.chats[cid]["name"],
                color=(1, 1, 1, 1) if is_curr else (0.5, 0.5, 0.5, 1),
                font_size='14sp',
                bold=is_curr,
                shorten=True,
                shorten_from='right',
                halign='left',
                valign='middle',
                size_hint=(None, None),
                width=dp(140)
            )
            lbl.bind(size=lbl.setter('text_size'))

            pin_btn = Button(
                text="!" if not is_pinned else "v",
                size_hint=(None, None),
                size=(dp(35), dp(35)),
                background_color=(0,0,0,0),
                color=ORANGE if is_pinned else (0.4, 0.4, 0.4, 1),
                font_size='16sp',
                bold=True
            )
            pin_btn.bind(on_release=lambda x, id=cid: self.toggle_pin(id))

            del_btn = Button(
                text="×",
                size_hint=(None, None),
                size=(dp(35), dp(35)),
                background_color=(0,0,0,0),
                color=(0.8, 0.2, 0.2, 0.8),
                font_size='18sp'
            )
            del_btn.bind(on_release=lambda x, id=cid: self.delete_chat(id))

            select_btn = Button(background_color=(0,0,0,0), size_hint=(None, None))
            select_btn.bind(on_release=lambda x, id=cid: self.switch_chat(id))

            with row.canvas.before:
                if is_curr:
                    Color(*ORANGE_LOW)
                    row.rect = RoundedRectangle(radius=[dp(12)])
                    Color(*ORANGE)
                    row.line = Line(width=1.2)
                else:
                    Color(1, 1, 1, 0.05)
                    row.rect = RoundedRectangle(radius=[dp(12)])

            def upd_ui(inst, value, l=lbl, p=pin_btn, d=del_btn, s=select_btn, r=row):
                capsule_w = dp(240)
                capsule_h = dp(38)
                start_x = dp(15)
                start_y = r.y + (r.height - capsule_h) / 2

                l.pos = (start_x + dp(10), r.y)
                l.height = r.height

                p.pos = (start_x + capsule_w - dp(75), start_y)
                d.pos = (start_x + capsule_w - dp(40), start_y)

                s.pos = (start_x, r.y)
                s.size = (capsule_w - dp(80), r.height)

                if hasattr(r, 'rect'):
                    r.rect.pos = (start_x, start_y)
                    r.rect.size = (capsule_w, capsule_h)
                if hasattr(r, 'line'):
                    r.line.rounded_rectangle = (start_x, start_y, capsule_w, capsule_h, dp(12))

            row.bind(pos=upd_ui, size=upd_ui)

            row.add_widget(lbl)
            row.add_widget(pin_btn)
            row.add_widget(del_btn)
            row.add_widget(select_btn)
            self.chat_list_layout.add_widget(row)

    def send_msg(self, *args):
        text = self.tin.text.strip()
        if not text: return
        if not self.chats[self.current_chat_id]["msgs"]:
            self.chats[self.current_chat_id]["name"] = text[:20]
            self.center_label.opacity = 0
        self.chats[self.current_chat_id]["msgs"].append({"text": text, "is_user": True})
        self.add_bubble(text, is_user=True)
        self.tin.text = ""
        self.refresh_chat_list()
        threading.Thread(target=self.get_ai_answer, args=(text, self.current_chat_id), daemon=True).start()

    def add_bubble(self, text, is_user=False):
        wrapper = BoxLayout(size_hint_y=None, padding=[dp(5), dp(2)])
        bubble = Label(text=text, size_hint=(None, None), padding=(dp(15), dp(10)), halign='left')
        bubble.bind(texture_size=bubble.setter('size'))
        max_w = Window.width * 0.75
        bubble.text_size = (max_w if bubble.texture_size[0] > max_w else None, None)
        with bubble.canvas.before:
            Color(*(0.7, 0.3, 0, 1) if is_user else (0.12, 0.12, 0.12, 1))
            rect = RoundedRectangle(radius=[dp(15)])
        bubble.bind(pos=lambda s,p: setattr(rect, 'pos', p), size=lambda s,z: setattr(rect, 'size', z))
        if is_user: wrapper.add_widget(Widget()); wrapper.add_widget(bubble)
        else: wrapper.add_widget(bubble); wrapper.add_widget(Widget())
        wrapper.height = bubble.height + dp(10)
        self.chat_box.add_widget(wrapper)
        Clock.schedule_once(lambda dt: setattr(self.scroll, 'scroll_y', 0))

    def get_ai_answer(self, prompt, cid):
        try:
            headers = {"Authorization": f"Bearer {API_KEY}", "Content-Type": "application/json"}
            payload = {
                "model": MODEL_TEXT,
                "messages": [
                    {"role": "system", "content": SYSTEM_PROMPT},
                    {"role": "user", "content": prompt}
                ],
                "temperature": 0.9,
                "max_tokens": 800
            }
            res = requests.post(URL, headers=headers, json=payload, timeout=30)
            ans = res.json()['choices'][0]['message']['content']
        except: ans = "ERROR"
        self.chats[cid]["msgs"].append({"text": ans, "is_user": False})
        if cid == self.current_chat_id: Clock.schedule_once(lambda dt, a=ans: self.add_bubble(a))
        self.save_data()

    def toggle_drawer(self, *args):
        tx = 0 if self.drawer.x < 0 else -self.drawer.width
        Animation(x=tx, duration=0.2, t='out_quad').start(self.drawer)

    def check_close_drawer(self, instance, touch):
        if self.drawer.x == 0 and touch.x > self.drawer.width: self.toggle_drawer(); return True
        return False

