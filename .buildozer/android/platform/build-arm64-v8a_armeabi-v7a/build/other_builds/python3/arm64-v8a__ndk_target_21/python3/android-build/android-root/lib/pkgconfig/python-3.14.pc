# See: man pkg-config
prefix=/home/hellomoto/igseek-app/.buildozer/android/platform/build-arm64-v8a_armeabi-v7a/build/other_builds/python3/arm64-v8a__ndk_target_21/python3/android-build/android-root
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: Python
Description: Build a C extension for Python
Requires:
Version: 3.14
Libs.private: -ldl  -lsqlite3 -lffi -lcrypto -lssl -lz -llog
Libs: -L${libdir} $(BLDLIBRARY)
Cflags: -I${includedir}/python3.14
